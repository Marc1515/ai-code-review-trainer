# =============================================================================
# AI Code Review Trainer — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` (or `.env.local`) and fill in real values. NEVER commit a file
# with real secrets — only this *.example template is committed. See SECURITY.md.
# Variables WITHOUT the NEXT_PUBLIC_ prefix are server-only and must never be
# exposed to the client.
# =============================================================================

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development

# --- AI provider --------------------------------------------------------------
# "ollama" — default; calls a local Ollama instance server-side (zero cost).
# "mock"   — canned reviews; for local dev and testing only.
AI_PROVIDER=ollama

# --- Ollama config (only used when AI_PROVIDER=ollama) -----------------------
# URL the app container uses to reach Ollama.
# On VPS with Docker networking: http://ollama:11434
# For local dev pointing at a host machine: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT_MS=90000

# --- Public app URL (safe to expose) -----------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (PostgreSQL + Prisma) -------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://app:app@localhost:5432/ai_code_review_trainer?schema=public

# --- Auth.js / NextAuth -------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=replace-me
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# GitHub OAuth app credentials
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me
# Google OAuth client credentials
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me

# --- Sentry -------------------------------------------------------------------
# Both vars point at the same DSN value; DSNs are safe to expose in client JS.
# Leave blank to disable Sentry entirely (app still works without it).
# Source map upload (SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT) is deferred
# to a future phase — see DECISIONS.md ADR-009.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Explicit environment tag shown in Sentry. Defaults to NODE_ENV when unset.
# SENTRY_ENVIRONMENT=development

# --- Postgres container vars (used by docker-compose.db.*.yml) ----------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=ai_code_review_trainer
