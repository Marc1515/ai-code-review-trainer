# =============================================================================
# Production environment template — deploys to trainer.marcespana.com
# Copy to `.env.production` (or the env file your prod compose loads) and fill
# in real values. Placeholders only; never commit real secrets. See DEPLOYMENT.md.
# =============================================================================

NODE_ENV=production
AI_PROVIDER=mock

NEXT_PUBLIC_APP_URL=https://trainer.marcespana.com

# Points at the persistent prod Postgres container:
#   ai-code-review-trainer-postgres-prod
DATABASE_URL=postgresql://app:replace-me@ai-code-review-trainer-postgres-prod:5432/ai_code_review_trainer?schema=public

# --- Auth.js / NextAuth (prod OAuth app credentials) --------------------------
AUTH_SECRET=replace-me
AUTH_URL=https://trainer.marcespana.com
AUTH_TRUST_HOST=true
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me

# --- Sentry (post-MVP) --------------------------------------------------------
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# --- Prod Postgres container vars ---------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=ai_code_review_trainer
