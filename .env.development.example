# =============================================================================
# Development environment template — deploys to dev-trainer.marcespana.com
# Copy to `.env.development` (or the env file your dev compose loads) and fill
# in real values. Placeholders only; never commit real secrets. See DEPLOYMENT.md.
# =============================================================================

NODE_ENV=development
AI_PROVIDER=ollama

# --- Ollama config ------------------------------------------------------------
# The dev app container reaches Ollama via the Docker backend network.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT_MS=90000

NEXT_PUBLIC_APP_URL=https://dev-trainer.marcespana.com

# Points at the persistent dev Postgres container:
#   ai-code-review-trainer-postgres-dev
DATABASE_URL=postgresql://app:replace-me@ai-code-review-trainer-postgres-dev:5432/ai_code_review_trainer?schema=public

# --- Auth.js / NextAuth (dev OAuth app credentials) ---------------------------
AUTH_SECRET=replace-me
AUTH_URL=https://dev-trainer.marcespana.com
AUTH_TRUST_HOST=true
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me

# --- Rate limiting (optional; these are the defaults) -------------------------
RATE_LIMIT_ANON_MAX=5
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_WINDOW_MS=60000

# --- Sentry -------------------------------------------------------------------
# Leave blank to run without Sentry (default for local dev).
# Source map upload vars (SENTRY_AUTH_TOKEN etc.) are deferred — see ADR-009.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Dev Postgres container vars ----------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=ai_code_review_trainer
